# Базовый URL API (видео, превью, тарифы)
VITE_API_BASE=http://localhost:3000

# URL Web App из Google Apps Script (для сохранения email в таблицу)
# Инструкция: scripts/google-apps-script.js
VITE_GOOGLE_SHEETS_WEB_APP_URL=

# JAVHD tour 581 — структура запроса тарифов и join (NATS)
VITE_JAVHD_TOUR_ID=581
# Base64 NATS code — из track ссылки
VITE_JAVHD_NATS_CODE=MjI3NDAuMi4yLjY4NS4wLjAuMC4wLjA
# URL API billing options. Пусто — используется хардкод. Пример: /api/billing или https://proxy.example.com/billing
VITE_JAVHD_BILLING_API=
# true — /track/{nats} (лишний paywall). false — сразу на биллера (signup.php)
VITE_JAVHD_USE_TRACK=false
# Базовый URL join (только при USE_TRACK=false)
VITE_JAVHD_JOIN_BASE=https://enter.javhd.com/signup
